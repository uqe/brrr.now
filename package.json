{
  "name": "brrr.now",
  "version": "1.3.0",
  "description": "Tiny TypeScript client for sending push notifications with brrr.now webhooks",
  "keywords": [
    "brrr",
    "brrr.now",
    "notification",
    "push-notification",
    "push-notifications",
    "typescript",
    "webhook"
  ],
  "homepage": "https://github.com/uqe/brrr.now#readme",
  "bugs": {
    "url": "https://github.com/uqe/brrr.now/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uqe/brrr.now.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bunup",
    "dev": "bunup --watch",
    "format": "oxfmt",
    "lint": "oxlint",
    "prepare": "bun simple-git-hooks",
    "release": "bumpp --commit --push --tag",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "bumpp": "^11.0.1",
    "bunup": "^0.16.31",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint && bun run type-check"
  }
}
